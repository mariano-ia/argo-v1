{
  "name": "argos-method",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/prerender-meta.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test:e2e": "playwright test e2e/odyssey.spec.ts e2e/auth-dashboard.spec.ts e2e/argo-one.spec.ts e2e/report.spec.ts e2e/chat.spec.ts e2e/health.spec.ts e2e/audio-health.spec.ts",
    "test:monkey": "playwright test e2e/monkey-odyssey.spec.ts e2e/monkey-signup.spec.ts",
    "qa:monitor": "node scripts/qa/lib/run-monitor.mjs",
    "qa:ai-eval": "tsx scripts/qa/ai-eval.ts",
    "qa:unit": "node scripts/qa/lib/scoring.test.mjs && node scripts/qa/lib/qa-env.test.mjs && node scripts/qa/lint-content.test.mjs && tsx --test scripts/qa/coach-helpers.test.ts && npm run check:coach-gen",
    "lint:content": "node scripts/qa/lint-content.mjs",
    "check:api-imports": "node scripts/qa/check-api-imports.mjs",
    "typecheck:api": "tsc -p tsconfig.api.json",
    "gen:coach": "tsx scripts/gen-coach-knowledge.ts",
    "check:coach-gen": "tsx scripts/gen-coach-knowledge.ts --check",
    "check:security": "node -r dotenv/config scripts/security/security-probe.mjs dotenv_config_path=.env.local"
  },
  "dependencies": {
    "@react-three/fiber": "^8.18.0",
    "@supabase/supabase-js": "^2.99.0",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.323.0",
    "micro": "^10.0.1",
    "posthog-js": "^1.378.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.4",
    "stripe": "^20.4.1",
    "tailwind-merge": "^2.2.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/three": "^0.183.1",
    "@vercel/node": "^5.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "dotenv": "^17.3.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "openai": "^6.32.0",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.3",
    "typescript": "^5.2.2",
    "vercel": "^54.0.0",
    "vite": "^5.1.0"
  }
}
