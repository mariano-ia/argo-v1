{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/category/:cat", "destination": "/blog/category/:cat/index.html" },
    { "source": "/pricing", "destination": "/pricing/index.html" },
    { "source": "/terms", "destination": "/terms/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/((?!api/).*)", "destination": "/app.html" }
  ],
  "crons": [
    {
      "path": "/api/item-quality-cron",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/blog-cron",
      "schedule": "0 10 * * 1,4"
    },
    {
      "path": "/api/retention-cron",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/child-memory-cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/puentes-reminder-cron",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/puentes-sync-cron",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/qa-monitor",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/report-recovery-cron",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/trial-lifecycle-cron",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/principia-detect",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/journey-canary",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/security-canary",
      "schedule": "15 * * * *"
    }
  ]
}
